{
  "schema": 1,
  "trusted_extensions": [
    {
      "name": "worldgraph",
      "source": "npm:worldgraph",
      "allow": [
        "mcp__worldgraph__*"
      ],
      "deny": [
        "Read(./.env)",
        "Read(./.env.*)",
        "Bash(rm:*)",
        "Bash(git push:*)",
        "Write(*)",
        "Edit(*)"
      ]
    }
  ]
}
