{
  "$schema": "https://opencode.ai/schema/opencode.json",
  "mcp": {
    "worldgraph": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "worldgraph@latest",
        "mcp",
        "start"
      ],
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "rm *": "deny",
      "git push *": "deny"
    },
    "webfetch": "ask"
  }
}
